{
  "rules": {
    "lobbies": {
      "$code": {
        ".write": "auth != null && (!data.exists() || auth.uid === data.child('host').val())",

        "host": { ".read": "auth != null" },
        "phase": { ".read": "auth != null" },
        "round": { ".read": "auth != null" },
        "phaseEndsAt": { ".read": "auth != null" },
        "paused": { ".read": "auth != null" },
        "pausedRemaining": { ".read": "auth != null" },
        "winner": { ".read": "auth != null" },
        "revoteEligible": { ".read": "auth != null" },
        "animation": { ".read": "auth != null" },
        "morning": { ".read": "auth != null" },
        "silence": { ".read": "auth != null" },
        "pirate": { ".read": "auth != null" },
        "seerInvestigations": { ".read": "auth != null" },
        "settings": { ".read": "auth != null" },

        "joinOrder": {
          ".read": "auth != null",
          "$uid": { ".write": "auth != null && auth.uid === $uid" }
        },

        "players": {
          ".read": "auth != null",
          "$uid": {
            ".write": "auth != null && (auth.uid === $uid || auth.uid === root.child('lobbies/' + $code + '/host').val())"
          }
        },

        "presence": {
          ".read": "auth != null",
          "$uid": { ".write": "auth != null && auth.uid === $uid" }
        },

        "dayVotes": {
          ".read": "auth != null",
          "$uid": { ".write": "auth != null && auth.uid === $uid" }
        },

        "log": {
          ".read": "auth != null",
          "$entry": { ".write": "auth != null" }
        },

        "wolfPack": {
          ".read": "auth != null && (root.child('lobbies/' + $code + '/wolfPack/' + auth.uid).exists() || auth.uid === root.child('lobbies/' + $code + '/host').val())"
        },

        "wolfVotes": {
          "$uid": {
            ".read": "auth != null && (auth.uid === root.child('lobbies/' + $code + '/host').val() || root.child('lobbies/' + $code + '/wolfPack/' + auth.uid).exists())",
            ".write": "auth != null && auth.uid === $uid"
          }
        },

        "nightActions": {
          "$uid": {
            ".read": "auth != null && auth.uid === root.child('lobbies/' + $code + '/host').val()",
            ".write": "auth != null && auth.uid === $uid"
          }
        },

        "abilityUsed": {
          "$uid": {
            ".read": "auth != null && auth.uid === $uid",
            ".write": "auth != null && auth.uid === $uid"
          }
        },

        "pendingReveal": {
          "$uid": {
            ".read": "auth != null && auth.uid === $uid",
            ".write": "auth != null && (auth.uid === $uid || auth.uid === root.child('lobbies/' + $code + '/host').val())"
          }
        },

        "nightResults": {
          "$uid": {
            ".read": "auth != null && auth.uid === $uid"
          }
        },

        "secrets": {
          "$uid": {
            ".read": "auth != null && auth.uid === $uid"
          }
        },

        "spectatorRoles": {
          "$uid": {
            ".read": "auth != null && (auth.uid === root.child('lobbies/' + $code + '/host').val() || root.child('lobbies/' + $code + '/players/' + auth.uid + '/isSpectator').val() === true)"
          }
        },

        "poison": {
          ".read": "auth != null && auth.uid === root.child('lobbies/' + $code + '/host').val()"
        }
      }
    }
  }
}
